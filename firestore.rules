rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - email: string (optional)
    //   - role: string (required, 'user' or 'admin')
    //
    // Collection: posts
    // Fields:
    //   - authorId: string (required)
    //   - authorName: string (required)
    //   - authorPhoto: string (optional)
    //   - content: string (required)
    //   - createdAt: timestamp (required)
    //   - likes: number (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName']) &&
             data.uid is string &&
             data.displayName is string &&
             data.displayName.size() > 0 && data.displayName.size() < 100;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'content', 'createdAt']) &&
             data.authorId is string &&
             data.authorName is string &&
             data.content is string &&
             data.content.size() > 0 && data.content.size() < 5000 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                      request.resource.data.role == resource.data.role;
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost(request.resource.data) && request.resource.data.authorId == request.auth.uid;
      allow update: if isDocOwner() && isValidPost(request.resource.data) &&
                      request.resource.data.authorId == resource.data.authorId;
      allow delete: if isDocOwner();
    }
  }
}
